---
import { testimonials } from '../data/testimonials';
---

<section id="depoimentos" class="relative bg-azul-petroleo py-24 grain overflow-hidden" aria-labelledby="depoimentos-titulo">
  <!-- Ambient light spots -->
  <div class="absolute top-0 left-1/4 w-64 h-64 rounded-full bg-azul-royal/10 blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-1/4 w-64 h-64 rounded-full bg-ambar-edison/8 blur-3xl" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-ambar-edison">Avaliações reais</span>
      <h2 id="depoimentos-titulo" class="mt-3 font-heading text-3xl font-bold text-branco sm:text-4xl lg:text-5xl">
        Quem Passa Pela Braun,<br />
        <span class="text-ambar-edison">Volta</span>
      </h2>
      <p class="mx-auto mt-4 max-w-md text-branco/50">
        Nota 4.8 no Google Maps. Veja o que nossos clientes dizem.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t, i) => (
        <article class={`reveal reveal-delay-${(i % 3) + 1} group flex flex-col rounded-2xl border border-branco/10 bg-azul-petroleo/60 p-6 backdrop-blur-sm transition-all duration-300 hover:border-azul-royal/30 hover:bg-azul-petroleo/80`}>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label={`Avaliação: ${t.rating} de 5 estrelas`}>
            {Array.from({ length: t.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="text-ambar-edison" aria-hidden="true"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="flex-1">
            <p class="text-sm leading-relaxed text-branco/80 italic">
              "{t.quote}"
            </p>
          </blockquote>

          <!-- Author -->
          <div class="mt-5 flex items-center justify-between">
            <div>
              <p class="text-sm font-bold text-branco">{t.name}</p>
              <p class="text-[11px] text-branco/40">{t.source}</p>
            </div>
            <span class="rounded-full bg-ambar-edison/10 px-3 py-1 text-[11px] font-medium text-ambar-edison">
              {t.service}
            </span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
