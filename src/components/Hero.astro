---
const base = import.meta.env.BASE_URL;
---

<section id="inicio" class="relative min-h-dvh flex items-center justify-center overflow-hidden grain">
  <!-- Background image with parallax -->
  <div class="absolute inset-0" id="hero-parallax">
    <img
      src={`${base}images/01-barba-closeup-hero.jpg`}
      alt="Barbeiro da Braun cortando cabelo de cliente, ambiente com iluminação quente e madeira escura"
      width="1920"
      height="1080"
      class="h-[120%] w-full object-cover scale-110"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      style="will-change: transform;"
    />
  </div>

  <!-- Multi-layer overlay for depth -->
  <div class="absolute inset-0 bg-gradient-to-b from-cafe-noite/50 via-cafe-noite/40 to-cafe-noite" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-cafe-noite/60 via-transparent to-cafe-noite/40" aria-hidden="true"></div>

  <!-- Vignette -->
  <div class="absolute inset-0" style="box-shadow: inset 0 0 200px 60px rgba(44,24,16,0.7);" aria-hidden="true"></div>

  <!-- Edison ambient light -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full edison-glow opacity-30 blur-3xl" aria-hidden="true" style="background: radial-gradient(circle, rgba(212,145,42,0.3) 0%, transparent 70%);"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-5xl px-4 py-32 text-center sm:px-6 lg:px-8">
    <!-- Small intro -->
    <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-ambar-edison/30 bg-cafe-noite/40 px-5 py-2 text-sm font-medium text-ambar-edison backdrop-blur-sm reveal">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
      Blumenau, SC &mdash; Desde 2011
    </p>

    <h1 class="font-heading text-5xl font-black leading-[0.95] text-branco sm:text-6xl md:text-7xl lg:text-8xl reveal reveal-delay-1">
      Onde Estilo<br />
      Encontra <span class="text-ambar-edison drop-shadow-[0_0_30px_rgba(212,145,42,0.4)]">Tradição</span>
    </h1>

    <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed text-branco/70 sm:text-xl reveal reveal-delay-2">
      Cada corte, cada traço de navalha — uma obra de arte pensada para quem você é.
    </p>

    <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center reveal reveal-delay-3">
      <a
        href="https://wa.me/554784334380?text=Olá! Gostaria de agendar um horário."
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 rounded-full bg-ambar-edison px-8 py-4 text-lg font-bold text-cafe-noite shadow-xl shadow-ambar-edison/20 transition-all duration-300 hover:bg-amarelo-fachada hover:shadow-2xl hover:shadow-ambar-edison/30 hover:-translate-y-1 active:translate-y-0 touch-action-manipulation"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-300 group-hover:rotate-12"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        Agende Seu Horário
      </a>

      <a
        href="#servicos"
        class="inline-flex items-center gap-2 rounded-full border border-branco/20 px-8 py-4 text-lg font-medium text-branco/80 backdrop-blur-sm transition-all duration-300 hover:border-ambar-edison/50 hover:text-ambar-edison hover:bg-ambar-edison/5"
      >
        Ver Serviços
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </a>
    </div>

    <!-- Trust strip inline -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-6 text-sm text-branco/40 reveal reveal-delay-4">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="text-ambar-edison" aria-hidden="true"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg>
        4.8 no Google
      </span>
      <span class="h-3 w-px bg-branco/20" aria-hidden="true"></span>
      <span>+14 anos</span>
      <span class="h-3 w-px bg-branco/20" aria-hidden="true"></span>
      <span>8 profissionais</span>
      <span class="h-3 w-px bg-branco/20" aria-hidden="true"></span>
      <span>Pix, cartão e mais</span>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div class="flex flex-col items-center gap-2 text-branco/30">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="h-8 w-5 rounded-full border border-branco/30 flex items-start justify-center p-1">
        <div class="h-2 w-1 rounded-full bg-ambar-edison animate-bounce"></div>
      </div>
    </div>
  </div>
</section>

<script>
  // Parallax on scroll
  const parallax = document.getElementById('hero-parallax');
  if (parallax && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight * 1.5) {
        parallax.style.transform = `translateY(${y * 0.3}px)`;
      }
    }, { passive: true });
  }
</script>
