---
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article class={`group relative overflow-hidden rounded-2xl bg-carvao-quente transition-all duration-500 hover:shadow-warm-lg h-full flex flex-col`}>
  <!-- Photo -->
  <div class="relative flex-1 min-h-0 overflow-hidden">
    <img
      src={`${base}/${member.photo.replace(/^\//, '')}`}
      alt={`${member.nickname} — ${member.role} da Braun Barbearia`}
      width="600"
      height="800"
      class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
      decoding="async"
    />

    <!-- Gradient overlay always visible at bottom -->
    <div class="absolute inset-0 bg-gradient-to-t from-carvao-quente via-carvao-quente/20 to-transparent"></div>

    <!-- Bio overlay — hover (desktop) ou toggle (mobile) -->
    <div class="bio-overlay absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-cafe-noite via-cafe-noite/80 to-cafe-noite/30 p-5 opacity-0 pointer-events-none transition-all duration-500 group-hover:opacity-100 group-hover:pointer-events-auto">
      <!-- Botão fechar (mobile) -->
      <button class="bio-close absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-full bg-black/50 text-white/70 hover:text-white lg:hidden" aria-label="Fechar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <p class="text-xs leading-relaxed text-branco/80 line-clamp-6 sm:text-sm">
        {member.bio}
      </p>
      <a
        href={member.ctaLink}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-flex items-center gap-2 self-start rounded-full bg-ambar-edison px-4 py-2 text-xs font-bold text-cafe-noite transition-all hover:bg-amarelo-fachada sm:text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {member.ctaLabel}
      </a>
    </div>

    {member.isFounder && (
      <span class="absolute left-3 top-3 rounded-full bg-ambar-edison px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-cafe-noite shadow-lg">
        Fundador{member.nickname === 'Nick' ? 'a' : ''}
      </span>
    )}
  </div>

  <!-- Info bar -->
  <div class="p-4 bg-carvao-quente">
    <div class="flex items-baseline gap-2">
      <h3 class="font-accent text-lg font-bold uppercase tracking-wide text-branco">
        {member.nickname}
      </h3>
      {member.realName && (
        <span class="text-xs text-branco/30">({member.realName})</span>
      )}
    </div>
    <p class="text-xs font-medium text-ambar-edison">{member.role}</p>
    <p class="mt-0.5 text-[11px] text-branco/40">
      {member.specialty}
    </p>
    <!-- Botão "Ver mais" — só no mobile -->
    <button
      class="bio-toggle mt-2.5 inline-flex w-full items-center justify-center gap-1.5 rounded-full border border-ambar-edison/30 bg-ambar-edison/10 py-2 text-xs font-medium text-ambar-edison transition-colors hover:bg-ambar-edison/20 lg:hidden"
      aria-expanded="false"
    >
      <span class="toggle-text">Ver mais</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="toggle-icon transition-transform duration-300" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </button>
  </div>
</article>

<script>
  document.querySelectorAll<HTMLElement>('.bio-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card    = btn.closest('article')!;
      const overlay = card.querySelector<HTMLElement>('.bio-overlay')!;
      const icon    = btn.querySelector<HTMLElement>('.toggle-icon')!;
      const label   = btn.querySelector<HTMLElement>('.toggle-text')!;
      const open    = btn.getAttribute('aria-expanded') === 'true';

      if (open) {
        overlay.style.opacity       = '';
        overlay.style.pointerEvents = '';
        btn.setAttribute('aria-expanded', 'false');
        label.textContent  = 'Ver mais';
        icon.style.transform = '';
      } else {
        overlay.style.opacity       = '1';
        overlay.style.pointerEvents = 'auto';
        btn.setAttribute('aria-expanded', 'true');
        label.textContent  = 'Ver menos';
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });

  document.querySelectorAll<HTMLElement>('.bio-close').forEach((btn) => {
    btn.addEventListener('click', () => {
      const card    = btn.closest('article')!;
      const overlay = card.querySelector<HTMLElement>('.bio-overlay')!;
      const toggle  = card.querySelector<HTMLElement>('.bio-toggle');
      const icon    = toggle?.querySelector<HTMLElement>('.toggle-icon');
      const label   = toggle?.querySelector<HTMLElement>('.toggle-text');

      overlay.style.opacity       = '';
      overlay.style.pointerEvents = '';
      toggle?.setAttribute('aria-expanded', 'false');
      if (label) label.textContent  = 'Ver mais';
      if (icon)  icon.style.transform = '';
    });
  });
</script>
