---
import { team } from '../data/team';
import TeamCard from './TeamCard.astro';

const barbers = team.filter((m) => !m.isFounder && !m.role.includes('Gestão'));
---

<section id="equipe" class="snap-section bg-[#0a0705] flex flex-col pt-28 overflow-hidden" aria-labelledby="equipe-titulo">

  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col flex-1 min-h-0 py-6">

    <div class="flex items-end justify-between mb-4 shrink-0 reveal">
      <div>
        <span class="text-xs font-bold uppercase tracking-[0.25em] text-ambar-edison">A Família</span>
        <h2 id="equipe-titulo" class="mt-1 font-accent text-3xl font-bold uppercase leading-none text-branco sm:text-4xl">
          Equipe de <span class="text-ambar-edison">Elite</span>
        </h2>
      </div>
      <p class="hidden sm:block text-xs text-branco/25 text-right max-w-[200px] leading-relaxed">
        Cada um com sua história,<br />todos com a mesma paixão.
      </p>
    </div>

    <!-- Mobile: scroll horizontal — Desktop: grid 5 colunas -->
    <div class="flex-1 min-h-0 hidden lg:grid lg:grid-cols-5 lg:gap-2">
      {barbers.map((member, i) => (
        <div class={`reveal reveal-delay-${(i % 5) + 1} h-full`}>
          <TeamCard member={member} />
        </div>
      ))}
    </div>

    <div id="team-scroll" class="flex-1 min-h-0 flex gap-3 overflow-x-auto snap-x snap-mandatory pb-2 lg:hidden [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {barbers.map((member, i) => (
        <div class={`reveal reveal-delay-${(i % 5) + 1} snap-start shrink-0 w-[62vw] sm:w-[45vw] h-full`}>
          <TeamCard member={member} />
        </div>
      ))}
    </div>

    <!-- Indicador de scroll — mobile only -->
    <div class="mt-3 mb-1 lg:hidden shrink-0 flex justify-center" aria-hidden="true">
      <div class="relative w-24 h-[3px] rounded-full bg-white/10">
        <div id="team-thumb" class="absolute top-0 left-0 h-full w-[20%] rounded-full bg-ambar-edison"></div>
      </div>
    </div>

  </div>

</section>

<script>
  const scrollEl = document.getElementById('team-scroll');
  const thumb    = document.getElementById('team-thumb');

  if (scrollEl && thumb) {
    const update = () => {
      const max      = scrollEl.scrollWidth - scrollEl.clientWidth;
      const progress = max > 0 ? scrollEl.scrollLeft / max : 0;
      thumb.style.left = `${progress * 80}%`;
    };
    scrollEl.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
