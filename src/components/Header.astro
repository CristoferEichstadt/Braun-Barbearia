---
const navLinks = [
  { label: 'Início', href: '#inicio' },
  { label: 'Serviços', href: '#servicos' },
  { label: 'Depoimentos', href: '#depoimentos' },
  { label: 'Equipe', href: '#equipe' },
  { label: 'Contato', href: '#contato' },
];
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8" aria-label="Navegação principal">
    <a href="/" class="flex items-center gap-2 group" aria-label="Braun Barbearia — Página inicial">
      <img
        src="/logo-braun.svg"
        alt="Logo da Braun Barbearia — desde 2011"
        width="160"
        height="48"
        class="h-10 w-auto sm:h-12 drop-shadow-lg transition-transform duration-300 group-hover:scale-105"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-1 md:flex" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="relative px-4 py-2 text-sm font-medium text-branco/70 transition-colors duration-200 hover:text-ambar-edison after:absolute after:bottom-0 after:left-1/2 after:h-0.5 after:w-0 after:bg-ambar-edison after:transition-all after:duration-300 hover:after:left-2 hover:after:w-[calc(100%-16px)]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="https://wa.me/554784334380?text=Olá! Gostaria de agendar um horário."
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 rounded-full bg-ambar-edison px-6 py-2.5 text-sm font-bold text-cafe-noite transition-all duration-300 hover:bg-amarelo-fachada hover:shadow-lg hover:shadow-ambar-edison/25 hover:-translate-y-0.5 active:translate-y-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      Agendar
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="flex h-11 w-11 items-center justify-center rounded-full text-branco/80 transition-all hover:bg-branco/10 hover:text-ambar-edison md:hidden"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden bg-cafe-noite/98 backdrop-blur-xl border-t border-ambar-edison/20 md:hidden"
    role="dialog"
    aria-label="Menu de navegação mobile"
  >
    <ul class="flex flex-col px-4 py-6 gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-nav-link flex items-center gap-3 rounded-xl px-4 py-3.5 text-lg font-medium text-branco/70 transition-all hover:bg-ambar-edison/10 hover:text-ambar-edison hover:pl-6"
          >
            <span class="h-1 w-1 rounded-full bg-ambar-edison/50" aria-hidden="true"></span>
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-4 pt-4 border-t border-branco/10">
        <a
          href="https://wa.me/554784334380?text=Olá! Gostaria de agendar um horário."
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 rounded-full bg-ambar-edison px-6 py-4 text-base font-bold text-cafe-noite transition-all hover:bg-amarelo-fachada"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          Agende Seu Horário
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  // Scroll-aware header
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 80) {
      header?.classList.add('bg-azul-petroleo/95', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/20');
    } else {
      header?.classList.remove('bg-azul-petroleo/95', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/20');
    }
    lastScroll = y;
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
