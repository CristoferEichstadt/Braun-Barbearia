---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { services } from '../data/services';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
const categories = ['Todos', 'Cabelo', 'Barba', 'Acabamento', 'Tratamento'] as const;

const categoryIcons: Record<string, string> = {
  Todos: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>`,
  Cabelo: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></svg>`,
  Barba: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`,
  Acabamento: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>`,
  Tratamento: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15.6 2.7a10 10 0 1 0 5.7 5.7"/><circle cx="12" cy="12" r="2"/><path d="M13.4 10.6 19 5"/></svg>`,
};

const badgeStyles: Record<string, string> = {
  ambar: 'bg-ambar-edison/15 text-ambar-edison',
  green: 'bg-green-100 text-green-700',
  conhaque: 'bg-conhaque/15 text-conhaque',
  vermelho: 'bg-vermelho-barbeiro/10 text-vermelho-barbeiro',
};

const faq = [
  {
    question: 'Preciso agendar ou aceita encaixe?',
    answer: 'Recomendamos agendamento online para garantir seu horário, mas aceitamos encaixes conforme disponibilidade.',
  },
  {
    question: 'Qual a forma de pagamento?',
    answer: 'Aceitamos mais de 12 formas: PIX, crédito, débito, Apple Pay, Google Pay, Mercado Pago e mais.',
  },
  {
    question: 'Vocês atendem crianças?',
    answer: 'Sim! Temos espaço kids e profissionais preparados para atender os pequenos com paciência e carinho.',
  },
];
---

<Layout
  title="Serviços | Braun Barbearia — Catálogo Completo"
  description="Confira todos os serviços da Braun Barbearia: cortes, barba, acabamentos, tratamentos. Preços acessíveis e agendamento online."
>
  <Header />

  <main class="pt-20">
    <!-- Page header -->
    <section class="bg-azul-petroleo py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="font-heading text-3xl font-bold text-branco sm:text-4xl lg:text-5xl">
          Nossos <span class="text-ambar-edison">Serviços</span>
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-branco/80">
          Catálogo completo com preços, duração e agendamento direto pelo WhatsApp.
        </p>
      </div>
    </section>

    <!-- Filters + Search -->
    <section class="bg-branco-quente py-8 border-b border-cinza-areia sticky top-16 z-30">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <!-- Category filters -->
          <div class="flex flex-wrap gap-2" role="group" aria-label="Filtrar serviços por categoria">
            {categories.map((cat) => (
              <button
                data-filter={cat}
                class={`filter-btn inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium transition-all duration-200 cursor-pointer ${
                  cat === 'Todos'
                    ? 'bg-azul-petroleo text-branco'
                    : 'bg-cinza-quente text-grafite-quente hover:bg-azul-petroleo/10'
                }`}
                aria-pressed={cat === 'Todos' ? 'true' : 'false'}
              >
                <span set:html={categoryIcons[cat]} />
                {cat}
              </button>
            ))}
          </div>

          <!-- Search -->
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-grafite-quente" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input
              type="search"
              id="service-search"
              placeholder="Buscar serviço..."
              class="w-full rounded-lg border border-cinza-areia bg-branco-quente py-2.5 pl-10 pr-4 text-sm text-carvao-quente placeholder:text-grafite-quente/60 focus:border-azul-royal focus:outline-none focus:ring-2 focus:ring-azul-royal/20 sm:w-64"
              aria-label="Buscar serviços por nome"
            />
          </div>
        </div>

        <!-- Sort -->
        <div class="mt-4 flex items-center gap-3">
          <label for="sort-select" class="text-sm text-grafite-quente">Ordenar:</label>
          <select
            id="sort-select"
            class="rounded-lg border border-cinza-areia bg-branco-quente px-3 py-2 text-sm text-carvao-quente focus:border-azul-royal focus:outline-none focus:ring-2 focus:ring-azul-royal/20"
          >
            <option value="popular">Mais populares</option>
            <option value="price-asc">Menor preço</option>
            <option value="price-desc">Maior preço</option>
            <option value="alpha">A–Z</option>
          </select>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="bg-cinza-quente py-12 sm:py-16" aria-label="Lista de serviços">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div id="services-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((service) => (
            <article
              class="service-card group flex flex-col overflow-hidden rounded-2xl border border-cinza-areia bg-branco-quente shadow-sm transition-all duration-200 hover:shadow-lg"
              data-category={service.category}
              data-name={service.name.toLowerCase()}
              data-price={service.priceValue ?? 999}
              data-badge={service.badge || ''}
            >
              <!-- Image -->
              <div class="relative aspect-[4/3] overflow-hidden">
                <img
                  src={`${base}${service.image.replace(/^\//, '')}`}
                  alt={`Serviço ${service.name} na Braun Barbearia`}
                  width="800"
                  height="600"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
                {service.badge && (
                  <span class={`absolute right-3 top-3 inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-semibold shadow-sm ${badgeStyles[service.badgeColor] || 'bg-cinza-quente text-grafite-quente'}`}>
                    {service.badge}
                  </span>
                )}
              </div>

              <!-- Content -->
              <div class="flex flex-1 flex-col p-6">
                <span class="mb-1 text-xs font-medium uppercase tracking-wider text-conhaque">
                  {service.category}
                </span>

                <h2 class="font-accent text-xl font-bold uppercase tracking-wide text-carvao-quente">
                  {service.name}
                </h2>

                <p class="mt-2 flex-1 text-sm leading-relaxed text-grafite-quente">
                  {service.fullDescription}
                </p>

                <div class="mt-4 flex items-center gap-3 text-sm text-grafite-quente">
                  <span class="inline-flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {service.duration}
                  </span>
                </div>

                <div class="mt-4 flex items-end justify-between border-t border-cinza-areia pt-4">
                  <span class="font-accent text-2xl font-bold text-ambar-edison tabular-nums">
                    {service.price}
                  </span>
                  <a
                    href={`https://wa.me/554784334380?text=Olá! Gostaria de agendar: ${service.name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg bg-azul-royal px-5 py-2.5 text-sm font-semibold text-branco transition-colors duration-200 hover:bg-azul-royal/90 cursor-pointer"
                    aria-label={`Agendar ${service.name} pelo WhatsApp`}
                  >
                    Agendar Este Serviço
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- Empty state -->
        <div id="empty-state" class="hidden py-16 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-grafite-quente/40" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <p class="mt-4 text-lg font-medium text-grafite-quente">Nenhum serviço encontrado</p>
          <p class="mt-1 text-sm text-grafite-quente/70">Tente outra busca ou limpe os filtros.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="bg-branco-quente py-16" aria-labelledby="faq-titulo">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 id="faq-titulo" class="font-heading text-2xl font-bold text-carvao-quente text-center sm:text-3xl">
          Perguntas Frequentes
        </h2>

        <div class="mt-8 space-y-4">
          {faq.map((item) => (
            <details class="group rounded-2xl border border-cinza-areia bg-cinza-quente p-6">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-carvao-quente list-none">
                {item.question}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-grafite-quente transition-transform duration-200 group-open:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-grafite-quente">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Floating CTA (mobile) -->
    <div class="fixed inset-x-0 bottom-0 z-40 border-t border-cinza-areia bg-branco-quente/95 backdrop-blur-sm p-3 sm:hidden">
      <a
        href="https://wa.me/554784334380?text=Olá! Gostaria de agendar um horário."
        target="_blank"
        rel="noopener noreferrer"
        class="flex w-full items-center justify-center gap-2 rounded-xl bg-green-600 py-3.5 text-base font-bold text-branco shadow-lg"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Agendar pelo WhatsApp
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.service-card');
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const searchInput = document.getElementById('service-search') as HTMLInputElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const grid = document.getElementById('services-grid')!;
  const emptyState = document.getElementById('empty-state')!;

  let activeCategory = 'Todos';
  let searchTerm = '';

  function filterAndSort() {
    let visibleCount = 0;
    const cardArray = Array.from(cards);

    // Filter
    cardArray.forEach((card) => {
      const category = card.dataset.category || '';
      const name = card.dataset.name || '';
      const matchesCategory = activeCategory === 'Todos' || category === activeCategory;
      const matchesSearch = name.includes(searchTerm.toLowerCase());
      const visible = matchesCategory && matchesSearch;
      card.style.display = visible ? '' : 'none';
      if (visible) visibleCount++;
    });

    // Sort visible cards
    const sortValue = sortSelect.value;
    const visibleCards = cardArray.filter((c) => c.style.display !== 'none');

    visibleCards.sort((a, b) => {
      switch (sortValue) {
        case 'price-asc':
          return (Number(a.dataset.price) || 999) - (Number(b.dataset.price) || 999);
        case 'price-desc':
          return (Number(b.dataset.price) || 0) - (Number(a.dataset.price) || 0);
        case 'alpha':
          return (a.dataset.name || '').localeCompare(b.dataset.name || '', 'pt');
        default: // popular: badges first
          const aHasBadge = a.dataset.badge ? 0 : 1;
          const bHasBadge = b.dataset.badge ? 0 : 1;
          return aHasBadge - bHasBadge;
      }
    });

    visibleCards.forEach((card) => grid.appendChild(card));

    emptyState.classList.toggle('hidden', visibleCount > 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCategory = btn.dataset.filter || 'Todos';
      filterBtns.forEach((b) => {
        const isActive = b.dataset.filter === activeCategory;
        b.classList.toggle('bg-azul-petroleo', isActive);
        b.classList.toggle('text-branco', isActive);
        b.classList.toggle('bg-cinza-quente', !isActive);
        b.classList.toggle('text-grafite-quente', !isActive);
        b.setAttribute('aria-pressed', String(isActive));
      });
      filterAndSort();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchTerm = searchInput.value;
    filterAndSort();
  });

  sortSelect?.addEventListener('change', filterAndSort);
</script>
